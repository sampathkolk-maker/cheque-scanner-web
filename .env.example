# Copy to .env. Keys are read by the backend only (the web server route, or the
# Rust desktop process) — never exposed to the browser. You can instead paste a
# key directly in the app's Settings; a key entered there takes precedence.
#
# The provider is chosen by the selected model, so set the key for whichever you use:
GEMINI_API_KEY=
ANTHROPIC_API_KEY=
