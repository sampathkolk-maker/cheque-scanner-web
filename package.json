{
  "name": "cheque-scanner-web",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Browser-first multi-cheque field extractor (GCC/Qatari bank cheques). Renders and segments in the browser; one thin server route holds the API key.",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "start": "node build",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "test": "tsx --tsconfig tsconfig.test.json tests/logic.test.ts",
    "build:tauri": "cross-env TAURI=1 vite build",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build"
  },
  "devDependencies": {
    "@sveltejs/adapter-node": "^5.2.0",
    "@sveltejs/kit": "^2.8.0",
    "@sveltejs/vite-plugin-svelte": "^4.0.0",
    "@types/node": "^22.9.0",
    "svelte": "^5.1.0",
    "svelte-check": "^4.0.0",
    "tslib": "^2.7.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vite": "^5.4.0",
    "@sveltejs/adapter-static": "^3.0.0",
    "@tauri-apps/cli": "^2.0.0",
    "cross-env": "^7.0.3"
  },
  "dependencies": {
    "pdfjs-dist": "^4.7.76"
  }
}
